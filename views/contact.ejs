            Follow me on INSTAGRAM — @ejthepropertydude
          </a>
        </li>
        <li>
          <a href="https://www.linkedin.com/in/eljuandurand/" class="contact-social-block__link contact-social-block__link--linkedin" target="_blank" rel="noopener noreferrer">
            <span class="contact-social-block__icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></span>
            Connect with me on LinkedIn
          </a>
        </li>
      </ul>
        </div>

        <div class="contact-hero-split__mascot">
          <div class="contact-mascot contact-mascot--eagle-logo" aria-hidden="true">
            <div class="contact-mascot__logo-wrap">
              <div class="contact-mascot__pulse" aria-hidden="true">
                <span class="contact-mascot__ring"></span>
                <span class="contact-mascot__ring contact-mascot__ring--d2"></span>
                <span class="contact-mascot__ring contact-mascot__ring--d3"></span>
              </div>
              <img
                src="/logo.png"
                alt=""
                class="contact-mascot__eagle-logo"
                width="220"
                height="auto"
                decoding="async"
              >
            </div>
          </div>
          <p class="contact-mascot__caption">Hustle Property</p>
        </div>
      </div>
    </section>

    <section class="form-card contact-page-card contact-page-card--form">
      <h2 class="contact-form-heading">Send a message</h2>
      <form method="POST" action="/contact" class="property-enquiry-form">
        <div class="form-group">
          <label for="c-name">Your name</label>
          <input id="c-name" name="name" type="text" required autocomplete="name" placeholder="Full name">
        </div>
        <div class="form-group">
          <label for="c-phone">Phone</label>
          <input id="c-phone" name="phone" type="tel" required autocomplete="tel" placeholder="Phone number">
        </div>
        <div class="form-group">
          <label for="c-email">Email (optional)</label>
          <input id="c-email" name="email" type="email" autocomplete="email" placeholder="you@example.com">
        </div>
        <div class="form-group">
          <label for="c-message">Message (optional)</label>
          <textarea id="c-message" name="message" rows="4" placeholder="How can we help?"></textarea>
        </div>
        <button type="submit" class="primary-btn">Send message</button>
      </form>
    </section>
  </main>

  <script>
    (function () {
      document.addEventListener("keydown", function (e) {
        if (e.ctrlKey && e.shiftKey && (e.key === "a" || e.key === "A")) {
          e.preventDefault();
          window.location.href = "/admin/login";
        }
      });
    })();
  </script>

</body>
</html>
