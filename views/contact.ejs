<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact us | Hustle Property</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="page-bg page-bg--contact">

  <header class="property-public-hero property-public-hero--contact">
    <a href="/" class="property-public-hero__back">← Back to listings</a>
    <div class="property-public-hero__brand">
      <div class="property-public-logo-panel">
        <a href="/" class="property-public-logo-link" aria-label="Hustle Property — home">
          <img src="/logo.png" alt="Hustle Property" class="property-public-logo" width="200" height="auto" decoding="async">
        </a>
      </div>
      <p class="property-public-hero__subtitle">Contact us</p>
    </div>
  </header>

  <main class="content-wrap contact-page-main">
    <% if (enquirySent) { %>
      <div class="admin-flash admin-flash--success" role="status">Thanks — your message was sent.</div>
    <% } %>
    <% if (enquiryError) { %>
      <div class="admin-flash" role="alert" style="background:#fef2f2;border-color:#fecaca;color:#991b1b;">Please enter your name and phone number.</div>
    <% } %>

    <section class="form-card contact-page-card contact-page-card--top contact-page-card--hero" id="contact-details">
      <div class="contact-hero-split">
        <div class="contact-hero-split__copy">
          <h1>Get in touch</h1>
          <p class="contact-page-lead contact-page-lead--muted">
            Name and phone are required below. Email and message are optional. Enquiries also appear in the admin <strong>Notifications</strong> area.
          </p>

          <ul class="contact-social-block" aria-label="Chat, email, and social">
        <li>
          <a href="https://wa.me/27826053539" class="contact-social-block__link contact-social-block__link--whatsapp" target="_blank" rel="noopener noreferrer">
