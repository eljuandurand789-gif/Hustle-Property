<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hustle Property</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="page-bg page-bg--home<% if (typeof searchActive !== 'undefined' && searchActive) { %> page-bg--home-search-results<% } %>">
<% const showSearchResults = typeof searchActive !== 'undefined' && searchActive; %>

  <header class="front-header front-hero front-hero--industrial front-hero--home-center">
    <div class="front-hero__center-stack">
      <div class="front-hero-brand">
        <a href="/" class="front-hero-brand-link" aria-label="Hustle Property — home">
          <img src="/logo.png" alt="" class="front-hero-logo-img" width="220" height="auto" decoding="async">
          <p class="front-hero-brand-name">Hustle Property</p>
        </a>
      </div>
      <p class="front-hero-tagline">Effective &amp; Ethical Industrial Property Brokers</p>
      <div class="header-top-actions front-hero__pill-row">
        <% if (!showSearchResults) { %>
        <a href="#home-featured" class="header-pill-btn header-pill-btn--ghost">Featured Listings</a>
        <% } %>
        <a href="/done-deals" class="header-pill-btn header-pill-btn--ghost">Done deals</a>
        <a href="#property-map-section" class="header-pill-btn header-pill-btn--ghost">Listing Map</a>
        <a href="/contact" class="header-pill-btn header-pill-btn--ghost">Contact</a>
        <a href="/admin/login" class="header-pill-btn header-pill-btn--ghost">Admin Login</a>
      </div>

      <section class="filter-panel home-hero-filter" aria-label="Search listings">
        <form method="GET" action="/" class="filter-form home-filter-form">
          <input type="hidden" name="home_search" value="1">
          <div class="filter-field">
            <label for="keywords">Keywords</label>
            <input id="keywords" type="text" name="keywords" value="<%= typeof keywords !== 'undefined' ? keywords : (typeof search !== 'undefined' ? search : '') %>" placeholder="Street, suburb, size, or other terms — use the Area filter for an exact suburb." autocomplete="off">
          </div>
          <div class="filter-field">
            <label for="area">Area</label>
            <select id="area" name="area">
              <option value="">All Areas</option>
              <option value="Maitland" <%= selectedArea === 'Maitland' ? 'selected' : '' %>>Maitland</option>
              <option value="Paarden Eiland" <%= selectedArea === 'Paarden Eiland' ? 'selected' : '' %>>Paarden Eiland</option>
            </select>
          </div>
          <div class="filter-field">
            <label for="status">Status</label>
            <select id="status" name="status">
              <option value="to-let" <%= selectedStatus === 'to-let' ? 'selected' : '' %>>To Let</option>
              <option value="for-sale" <%= selectedStatus === 'for-sale' ? 'selected' : '' %>>For Sale</option>
              <option value="" <%= selectedStatus === '' ? 'selected' : '' %>>All statuses</option>
            </select>
          </div>
          <div class="filter-field">
            <label for="property_type">Type</label>
            <select id="property_type" name="property_type">
              <option value="">All types</option>
              <option value="industrial" <%= typeof selectedPropertyType !== 'undefined' && selectedPropertyType === 'industrial' ? 'selected' : '' %>>Industrial</option>
              <option value="office" <%= typeof selectedPropertyType !== 'undefined' && selectedPropertyType === 'office' ? 'selected' : '' %>>Office</option>
            </select>
          </div>
          <div class="home-filter-form__ranges" role="group" aria-label="Power and height minimums">
            <div class="filter-field filter-field--range-compact">
              <label for="amps_min">Power min (A)</label>
              <input id="amps_min" class="home-filter-range-input" type="text" name="amps_min" inputmode="numeric" autocomplete="off" placeholder="e.g. 40" value="<%= typeof ampsMin !== 'undefined' ? ampsMin : '' %>">
            </div>
            <div class="filter-field filter-field--range-compact">
              <label for="height_min">Height min (m)</label>
              <input id="height_min" class="home-filter-range-input" type="text" name="height_min" inputmode="decimal" autocomplete="off" placeholder="e.g. 5" value="<%= typeof heightMin !== 'undefined' ? heightMin : '' %>">
            </div>
            <button type="submit" class="search-btn">Search</button>
            <a href="/" class="secondary-btn small-clear-btn">Clear Filters</a>
          </div>
        </form>
      </section>
    </div>
  </header>

  <main class="content-wrap">
    <% if (!showSearchResults) { %>
    <section class="home-featured-section" id="home-featured" aria-label="Featured Listings">
      <div class="home-featured-section__orbit" aria-hidden="true"></div>
      <div class="home-featured-section__frost" aria-hidden="true"></div>
      <div class="home-featured-section__inner">
      <h2 class="home-featured-section__title" id="home-featured-observe">Featured Listings</h2>
      <p class="home-featured-section__subtitle">Hand-picked for your business</p>
      <% const fh = typeof featuredHome !== 'undefined' ? featuredHome : []; %>
      <% const hasAny = fh.some((s) => !s.empty); %>
      <% if (hasAny || fh.length) { %>
        <div class="home-featured-grid">
          <% fh.forEach((slide) => { %>
            <article class="home-featured-card <%= slide.empty ? 'home-featured-card--empty' : '' %> <%= !slide.empty && slide.featureStyle === 'api' ? 'home-featured-card--api-feature' : '' %>">
              <% if (!slide.empty && slide.featureStyle === 'api') { %>
                <div class="home-featured-api">
                  <p class="home-featured-api__label">Featured listing</p>
                  <div class="home-featured-api__frame">
                    <div class="home-featured-api__media">
                      <% if (slide.galleryImages && slide.galleryImages.length) { %>
                        <img src="<%= slide.galleryImages[0] %>" alt="" class="home-featured-api__img">
                      <% } else if (slide.cardImage) { %>
                        <img src="/uploads/<%= slide.cardImage %>" alt="" class="home-featured-api__img">
                      <% } else { %>
                        <div class="home-featured-api__placeholder">No image</div>
                      <% } %>
                    </div>
                    <div class="home-featured-api__body">
                      <p class="home-featured-api__area"><%= slide.area || "Cape Town" %> · <%= slide.propertyTypeLabel || "Industrial" %></p>
                      <h2 class="home-featured-api__title"><%= slide.name %></h2>
                      <p class="home-featured-api__line"><strong>Size</strong> <%= slide.size || "—" %></p>
                      <p class="home-featured-api__price"><%= slide.price || "—" %></p>
                      <a href="<%= slide.url %>" class="primary-btn home-featured-api__cta">View property</a>
                    </div>
                  </div>
                </div>
              <% } else if (!slide.empty) { %>
                <div class="home-featured-card__media <% if (slide.galleryImages && slide.galleryImages.length > 1) { %>home-featured-card__media--cycle<% } %>"<% if (slide.galleryImages && slide.galleryImages.length > 1) { %> data-feature-gallery='<%- JSON.stringify(slide.galleryImages) %>'<% } %>>
                  <% if (slide.galleryImages && slide.galleryImages.length) { %>
                    <img src="<%= slide.galleryImages[0] %>" alt="" class="home-featured-card__img home-featured-card__img--a">
                    <% if (slide.galleryImages.length > 1) { %>
                      <img src="<%= slide.galleryImages[1] %>" alt="" class="home-featured-card__img home-featured-card__img--b" aria-hidden="true">
                    <% } %>
                  <% } else if (slide.cardImage) { %>
                    <img src="/uploads/<%= slide.cardImage %>" alt="" class="home-featured-card__img">
                  <% } else { %>
                    <div class="home-featured-card__placeholder">No image</div>
                  <% } %>
                  <div class="home-featured-card__overlay"></div>
                </div>
                <div class="home-featured-card__body">
                  <p class="home-featured-card__area-kicker"><%= slide.area || "Cape Town" %> · <%= slide.propertyTypeLabel || "Industrial" %></p>
                  <h2 class="home-featured-card__title"><%= slide.name %></h2>
                  <p class="home-featured-card__line"><strong>Size</strong> <%= slide.size || "—" %></p>
                  <p class="home-featured-card__price"><%= slide.price || "—" %></p>
                  <% if (slide.features && slide.features.length) { %>
                    <ul class="home-featured-card__features">
                      <% slide.features.forEach((f) => { %>
                        <li><%= f %></li>
                      <% }) %>
                    </ul>
                  <% } %>
                  <a href="<%= slide.url %>" class="primary-btn home-featured-card__cta">View property</a>
                </div>
              <% } else { %>
                <div class="home-featured-card__empty-inner">
                  <p class="home-featured-card__empty-title">No listing selected</p>
                  <p class="home-featured-card__empty-hint">Admin → Featured Listings (homepage)</p>
                </div>
              <% } %>
            </article>
          <% }); %>
        </div>
      <% } else { %>
        <div class="home-featured-empty">Featured listings will appear here once assigned in admin.</div>
      <% } %>
      </div>
    </section>
    <% } %>

    <% if (showSearchResults) { %>
    <div class="home-search-results-shell">
      <div class="home-search-results-shell__aurora" aria-hidden="true"></div>
      <div class="home-search-results-shell__shine" aria-hidden="true"></div>
    <% } %>

    <div class="home-browse-stack">
      <div class="home-browse-stack__listings" id="home-search-results">
        <div class="home-listings-wrap<%= showSearchResults ? ' home-listings-wrap--search-mode' : '' %>">
          <div class="home-listings-toolbar">
            <h2 class="home-listings-toolbar__title"><%= showSearchResults ? 'Search results' : 'Browse listings' %></h2>
            <form class="home-browse-area-form" method="GET" action="/" aria-label="Filter browse by area">
              <input type="hidden" name="home_search" value="1">
              <input type="hidden" name="keywords" value="<%= typeof keywords !== 'undefined' ? keywords : '' %>">
              <input type="hidden" name="status" value="<%= typeof selectedStatus !== 'undefined' ? selectedStatus : '' %>">
              <input type="hidden" name="property_type" value="<%= typeof selectedPropertyType !== 'undefined' ? selectedPropertyType : '' %>">
              <input type="hidden" name="amps_min" value="<%= typeof ampsMin !== 'undefined' ? ampsMin : '' %>">
              <input type="hidden" name="height_min" value="<%= typeof heightMin !== 'undefined' ? heightMin : '' %>">
              <label class="home-browse-area-form__label" for="browse-area">Area</label>
              <select class="home-browse-area-form__select" id="browse-area" name="area" onchange="navigateBrowseByArea(this)">
                <option value="" <%= !selectedArea ? 'selected' : '' %>>All areas</option>
                <option value="Maitland" <%= selectedArea === 'Maitland' ? 'selected' : '' %>>Maitland</option>
                <option value="Paarden Eiland" <%= selectedArea === 'Paarden Eiland' ? 'selected' : '' %>>Paarden Eiland</option>
              </select>
            </form>
          </div>
        <% if (!properties || properties.length === 0) { %>
          <section class="empty-state home-listings-empty">
            <h2>No properties found</h2>
            <p>Try different keywords, area, power (amps), or height — or <a href="/contact">contact us</a> for a shortlist.</p>
          </section>
        <% } else { %>
        <section class="property-grid home-grid">
          <% properties.forEach(property => { %>
            <article class="property-card <%= property.images && property.images.length > 1 ? 'property-card--gallery' : '' %>"
              <% if (property.images && property.images.length > 1) { %>
                data-gallery='<%- JSON.stringify(property.images.map(i => "/uploads/" + i.filename)) %>'
              <% } %>
            >
              <div class="card-main-image-wrap">
                <% if (property.video_filename) { %>
                  <span class="property-card-video-badge">Video</span>
                <% } %>
                <% if (property.cardImage) { %>
                  <a href="/property/<%= property.id %>" class="card-main-image-link" aria-label="View <%= property.name %> listing">
                    <img id="main-card-image-<%= property.id %>" src="/uploads/<%= property.cardImage %>" alt="<%= property.name %>" class="card-main-image">
                  </a>
                <% } else { %>
                  <a href="/property/<%= property.id %>" class="card-main-image-link card-main-image-link--empty" aria-label="View <%= property.name %>">
                    <div class="no-image large-no-image">No Image</div>
                  </a>
                <% } %>
              </div>
              <% if (property.images && property.images.length > 0) { %>
                <div class="thumb-scroll-row">
                  <% property.images.slice(0, 10).forEach((image, tidx) => { %>
                    <img src="/uploads/<%= image.filename %>" alt="" class="homepage-thumb" onclick="var m=document.getElementById('main-card-image-<%= property.id %>');if(m)m.src='/uploads/<%= image.filename %>';">
                  <% }) %>
                </div>
              <% } %>
              <div class="property-content compact-content">
                <div class="status-badge"><%= property.statusLabel %></div>
                <h3><%= property.name %></h3>
                <p><strong>Type:</strong> <%= property.propertyTypeLabel || "—" %></p>
                <p><strong>Size:</strong> <%= property.size || "-" %></p>
                <p><strong>Location:</strong> <%= property.address || "-" %></p>
                <p><strong>Availability:</strong> <%= property.availabilityDisplay || "-" %></p>
                <p><strong>Area:</strong> <%= property.area || "-" %></p>
                <a href="/property/<%= property.id %>" class="view-button">View Listing</a>
              </div>
            </article>
          <% }) %>
        </section>
        <% } %>
        </div>
      </div>
      <div class="home-browse-stack__map">
        <section class="map-section<%= showSearchResults ? ' map-section--search-mode' : '' %> map-section--split-col" id="property-map-section" aria-label="Listing map">
          <div class="map-card map-card--interactive">
            <h2>Listing Map</h2>
            <p class="map-note">Pins show active listings (To Let / For Sale).</p>
            <div id="property-map" class="property-leaflet-map" role="application" aria-label="Listing map — Cape Town"></div>
            <p class="map-loading" id="map-loading">Loading map…</p>
          </div>
        </section>
      </div>
    </div>

    <% if (showSearchResults) { %>
    </div>
    <% } %>

    <section class="home-contact-social" aria-label="Contact and social">
      <p class="home-contact-social__cpt">CPT: <a href="tel:+27826053539">+27 82 605 3539</a></p>
      <h2 class="home-contact-social__title">Follow us on social media</h2>
      <ul class="home-social-links">
        <li>
          <a href="https://www.instagram.com/ejthepropertydude/" class="home-social-links__a home-social-links__a--instagram" target="_blank" rel="noopener noreferrer">
            <span class="home-social-links__icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></span>
            Instagram
          </a>
        </li>
        <li>
          <a href="https://www.linkedin.com/in/eljuandurand/" class="home-social-links__a home-social-links__a--linkedin" target="_blank" rel="noopener noreferrer">
            <span class="home-social-links__icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></span>
            LinkedIn
          </a>
        </li>
        <li>
          <a href="https://wa.me/27826053539" class="home-social-links__a home-social-links__a--whatsapp" target="_blank" rel="noopener noreferrer">
            <span class="home-social-links__icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.881 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg></span>
            WhatsApp
          </a>
        </li>
      </ul>
      <p class="home-contact-social__more"><a href="/contact" class="home-contact-social__contact-link">Contact us</a> for enquiries and viewings.</p>
      <p class="home-footer-faq"><a href="/faq" class="home-footer-faq__link">Frequently asked questions</a></p>
    </section>
  </main>

  <div class="eagle-chat-launcher" id="eagle-chat-launcher">
    <div class="eagle-chat-launcher__shell theme-orbit-shell theme-orbit-shell--fab">
      <div class="theme-orbit-shell__orbit" aria-hidden="true"></div>
      <div class="theme-orbit-shell__frost" aria-hidden="true"></div>
      <div class="eagle-chat-launcher__inner theme-orbit-shell__inner">
        <button type="button" class="eagle-chat-fab" id="eagle-chat-fab" aria-haspopup="dialog" aria-label="Chat to the Eagle">
          <img src="/soloeagle.png" alt="" class="eagle-chat-fab__img" width="80" height="80" decoding="async">
          <span class="eagle-chat-fab__label">Chat to the Eagle</span>
        </button>
      </div>
      <button type="button" class="eagle-chat-launcher__dismiss" id="eagle-chat-launcher-dismiss" aria-label="Hide chat launcher for this browser session" title="Hide until you close this tab">&times;</button>
    </div>
  </div>

  <div class="home-modal" id="quiz-modal" role="dialog" aria-modal="true" aria-labelledby="quiz-title" hidden>
    <div class="home-modal__backdrop" id="quiz-modal-backdrop"></div>
    <div class="home-modal__panel-wrap theme-orbit-shell theme-orbit-shell--modal">
      <div class="theme-orbit-shell__orbit" aria-hidden="true"></div>
      <div class="theme-orbit-shell__frost" aria-hidden="true"></div>
      <div class="home-modal__panel theme-orbit-shell__inner">
        <div class="home-modal__topbar">
          <button type="button" class="home-modal__close" id="quiz-modal-close" aria-label="Exit chat">Exit</button>
        </div>
        <div class="quiz-eagle-hint">
          <img src="/soloeagle.png" alt="" class="quiz-eagle-mascot" width="280" height="280" decoding="async">
          <p>The Eagle shortlists warehouses to match what you need.</p>
        </div>
        <h2 id="quiz-title" class="quiz-title">Find your ideal space</h2>
        <div id="quiz-steps"></div>
        <div id="quiz-results" class="quiz-results" hidden>
          <h3>Your top matches</h3>
          <div id="quiz-match-cards" class="quiz-match-cards"></div>
          <a href="/contact" class="primary-btn quiz-cta">Arrange a viewing</a>
        </div>
        <div class="home-modal__footer">
          <button type="button" class="secondary-btn home-modal__close-footer" id="quiz-modal-close-footer">Close</button>
        </div>
      </div>
    </div>
  </div>

  <script type="application/json" id="home-quiz-json"><%- quizPropertiesJson %></script>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
  <script src="/home.js"></script>
  <script src="/browse-area.js"></script>
  <script>
    (function () {
      document.querySelectorAll(".property-card--gallery").forEach(function (card) {
        var raw = card.getAttribute("data-gallery");
        if (!raw) return;
        var urls;
        try { urls = JSON.parse(raw); } catch (e) { return; }
        if (!urls || urls.length < 2) return;
        var img = card.querySelector(".card-main-image");
        if (!img) return;
        var idx = 0, timer, initialSrc = img.getAttribute("src");
        card.addEventListener("mouseenter", function () {
          timer = setInterval(function () {
            idx = (idx + 1) % urls.length;
            img.src = urls[idx];
          }, 1600);
        });
        card.addEventListener("mouseleave", function () {
          clearInterval(timer);
          if (initialSrc) img.src = initialSrc;
          idx = 0;
        });
      });
    })();
  </script>
  <script>
    (function () {
      var el = document.getElementById("property-map");
      var loading = document.getElementById("map-loading");
      if (!el || typeof L === "undefined") return;
      var map = L.map(el, { scrollWheelZoom: true }).setView([-33.9258, 18.4232], 11);
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", { maxZoom: 19, attribution: "&copy; OpenStreetMap" }).addTo(map);
      var icon = L.icon({ iconUrl: "/pin.png", iconSize: [56, 64], iconAnchor: [28, 64], popupAnchor: [0, -64], className: "map-pin-leaflet-icon" });
      fetch("/api/map-properties")
        .then(function (r) { if (!r.ok) throw new Error("Map API failed"); return r.json(); })
        .then(function (points) {
          if (loading) loading.style.display = "none";
          if (!points || !points.length) {
            if (loading) { loading.textContent = "No listings to show on the map yet."; loading.style.display = "block"; }
            return;
          }
          var group = [];
          points.forEach(function (p) {
            var m = L.marker([p.lat, p.lng], { icon: icon });
            var html = "<strong>" + String(p.name || "Property").replace(/</g, "&lt;") + "</strong><br>" +
              (p.typeLabel ? String(p.typeLabel).replace(/</g, "&lt;") + "<br>" : "") +
              (p.area ? String(p.area).replace(/</g, "&lt;") + "<br>" : "") +
              (p.address ? String(p.address).replace(/</g, "&lt;") + "<br>" : "") +
              '<a href="' + p.url + '">View listing</a>';
            m.bindPopup(html);
            m.addTo(map);
            group.push([p.lat, p.lng]);
          });
          if (group.length) map.fitBounds(group, { padding: [36, 36], maxZoom: 14 });
        })
        .catch(function () {
          if (loading) { loading.textContent = "Could not load map data."; loading.style.display = "block"; }
        });
    })();
  </script>
</body>
</html>
