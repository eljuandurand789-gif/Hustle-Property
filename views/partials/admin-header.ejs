<% const nav = typeof adminNavActive !== "undefined" ? adminNavActive : "dashboard"; %>
<% const heroTag = typeof adminHeroTagline !== "undefined" ? adminHeroTagline : "Admin Dashboard"; %>
<header class="admin-hero admin-hero--dashboard">
  <div class="admin-hero__nav admin-hero__nav--split">
    <div class="admin-hero__nav-left" role="navigation" aria-label="Primary">
      <a href="/" class="admin-nav-pill" target="_blank" rel="noopener noreferrer">
        <span class="admin-nav-pill__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5M21 3v5.25M21 3h-5.25M21 3l-9 9" /></svg>
        </span>
        <span class="admin-nav-pill__text">View live site</span>
      </a>
      <a href="/admin/featured-home" class="admin-nav-pill <%= nav === 'featured' ? 'admin-nav-pill--accent' : '' %>">
        <span class="admin-nav-pill__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" /></svg>
        </span>
        <span class="admin-nav-pill__text">Featured Listings</span>
      </a>
    </div>

    <div class="admin-hero__nav-right" role="navigation" aria-label="Admin shortcuts">
      <a href="/admin" class="admin-nav-pill admin-nav-pill--listings <%= nav === 'dashboard' ? 'admin-nav-pill--listings-active' : '' %>" title="Saved property listings">
        <span class="admin-nav-pill__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.65" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zm13.5-9.75A2.25 2.25 0 0118 3.75h2.25A2.25 2.25 0 0122.5 6v2.25a2.25 2.25 0 01-2.25 2.25H18a2.25 2.25 0 01-2.25-2.25V6zm0 9.75A2.25 2.25 0 0118 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H18a2.25 2.25 0 01-2.25-2.25v-2.25z" /></svg>
        </span>
        <span class="admin-nav-pill__text">Listings</span>
      </a>
      <a href="/admin/buildings" class="admin-nav-icon <%= nav === 'buildings' ? 'admin-nav-icon--active' : '' %>" title="Buildings &amp; parks" aria-label="Buildings and parks">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.65" stroke="currentColor" width="22" height="22" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" /></svg>
      </a>
      <a href="/admin/notifications" class="admin-nav-icon <%= nav === 'notifications' ? 'admin-nav-icon--active' : '' %>" title="Lease notifications" aria-label="Lease notifications">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.65" stroke="currentColor" width="22" height="22" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" /></svg>
      </a>
      <a href="/admin/agent-zone" class="admin-nav-icon <%= nav === 'agentZone' ? 'admin-nav-icon--active' : '' %>" title="Deals &amp; commission" aria-label="Deals and commission">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.71c.09 1.12 1.08 1.87 2.57 1.87 1.38 0 2.37-.73 2.37-1.84 0-1.05-.95-1.54-2.51-1.88l-.89-.21c-2.29-.55-3.39-1.62-3.39-3.56 0-1.74 1.39-2.95 3.11-3.32V4h2.67v1.95c1.86.45 2.79 1.86 2.85 3.39H14.3c-.05-.66-.59-1.62-1.77-1.62-1.07 0-1.77.64-1.77 1.5 0 .85.65 1.29 2.31 1.65l.88.2c2.55.58 3.65 1.62 3.65 3.47 0 1.89-1.42 3.09-3.11 3.44z"/></svg>
      </a>
      <form action="/admin/logout" method="POST" class="logout-form admin-nav-logout-form">
        <button type="submit" class="admin-nav-icon admin-nav-icon--danger" title="Log out" aria-label="Log out">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.65" stroke="currentColor" width="22" height="22" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" /></svg>
        </button>
      </form>
    </div>
  </div>

  <div class="admin-hero__center">
    <div class="admin-logo-panel">
      <a href="/admin" class="admin-hero-eagle-link" aria-label="Dashboard — saved listings">
        <img src="/logo.png" alt="" class="admin-hero-logo" width="140" height="auto" decoding="async">
      </a>
    </div>
    <p class="admin-hero-tagline"><%= heroTag %></p>
  </div>
</header>
